{
  "name": "trenith-tools",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "install:ci": "bash scripts/install-ci.sh",
    "prepare:wasm": "bash scripts/prepare-wasm.sh",
    "predev": "npm run prepare:wasm",
    "predev:next": "npm run prepare:wasm",
    "prebuild": "npm run prepare:wasm",
    "prebuild:vercel": "npm run prepare:wasm",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vite",
    "build": "bash scripts/build-verified.sh",
    "build:vercel": "next build",
    "build:extension": "wxt build",
    "build:extension:firefox": "wxt build -b firefox",
    "zip:extension": "wxt zip && wxt zip -b firefox",
    "dev:next": "next dev",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && npm run build:extension && npm run build:extension:firefox && node --test tests/*.test.mjs",
    "test:watch": "node --test tests/watch-*.test.mjs",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "lint": "bash scripts/sites-env.sh -- eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern .output --ignore-pattern .wxt --ignore-pattern public/ffmpeg",
    "search:indexnow": "node scripts/submit-indexnow.mjs",
    "db:generate": "bash scripts/sites-env.sh -- drizzle-kit generate"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@uswriting/exiftool": "^1.0.9",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "drizzle-orm": "0.45.2",
    "jszip": "^3.10.1",
    "next": "16.2.6",
    "pdf-lib": "^1.17.1",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "@wxt-dev/module-react": "^1.2.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0",
    "wxt": "^0.20.27"
  },
  "type": "module",
  "displayName": "Trenith Tools",
  "overrides": {
    "postcss": "^8.5.10"
  }
}
